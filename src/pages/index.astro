---
import ProjectCard from "../components/ProjectCard.astro";

const pageTitle = "Spencer Fletcher | Software Engineer";
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="Spencer Fletcher — software engineer studying CS at UBC. Experience with compiler tooling, full-stack web platforms, and mobile apps."
		/>
		<title>{pageTitle}</title>

		<link rel="icon" type="image/png" href="/logo.png" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..800;1,9..40,300..800&family=DM+Mono:wght@400;500&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			:root {
				--bg-primary: #0f0f13;
				--bg-card: #1a1a23;
				--bg-card-hover: #22222e;
				--bg-featured: #1c1c2e;
				--text-primary: #f0eff4;
				--text-secondary: #a09fb1;
				--accent: #8b7cf7;
				--accent-glow: rgba(139, 124, 247, 0.15);
				--accent-subtle: rgba(139, 124, 247, 0.08);
				--border: rgba(255, 255, 255, 0.13);
				--font-body:
					"DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				--font-mono: "DM Mono", "SF Mono", monospace;
			}

			* {
				margin: 0;
				box-sizing: border-box;
			}

			body {
				background-color: var(--bg-primary);
				color: var(--text-primary);
				font-family: var(--font-body);
				padding: 2rem;
				display: flex;
				justify-content: center;
				line-height: 1.65;
				-webkit-font-smoothing: antialiased;
			}

			.container {
				max-width: 860px;
				width: 100%;
			}

			/* Typography */
			h1 {
				font-size: 3rem;
				font-weight: 700;
				letter-spacing: -0.03em;
				line-height: 1.1;
				margin-bottom: 1.25rem;
			}

			h2 {
				font-size: 1.1rem;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--text-secondary);
				margin-bottom: 1.25rem;
			}

			h3 {
				font-size: 1.2rem;
				font-weight: 600;
				margin-bottom: 0;
			}

			a {
				color: var(--accent);
				text-decoration: none;
				font-weight: 500;
				transition: color 0.2s ease;
			}

			a:hover {
				color: var(--text-primary);
			}

			p {
				margin-bottom: 0;
			}

			strong {
				color: var(--text-primary);
				font-weight: 600;
			}

			main {
				margin-top: 3rem;
			}

			section {
				margin-bottom: 3rem;
			}

			/* Header */
			header {
				padding-bottom: 3rem;
				margin-bottom: 2.5rem;
				border-bottom: 1px solid var(--border);
			}

			.eyebrow {
				font-family: var(--font-mono);
				font-size: 0.8rem;
				color: var(--accent);
				letter-spacing: 0.04em;
				margin-bottom: 0.75rem;
			}

			.subtitle {
				font-size: 1.1rem;
				color: var(--text-secondary);
				line-height: 1.7;
				font-weight: 400;
			}

			.header-cta {
				display: flex;
				gap: 0.75rem;
				margin-top: 2rem;
			}

			.cta-button {
				display: inline-block;
				padding: 0.6rem 1.4rem;
				border-radius: 8px;
				text-decoration: none;
				font-weight: 600;
				font-size: 0.85rem;
				transition: all 0.2s ease;
				border: 1.5px solid var(--accent);
				background: var(--accent);
				color: var(--bg-primary);
				letter-spacing: 0.01em;
			}

			.cta-button:hover {
				background: transparent;
				color: var(--accent);
			}

			.cta-button-secondary {
				background: transparent;
				color: var(--text-primary);
				border-color: var(--border);
			}

			.cta-button-secondary:hover {
				border-color: var(--accent);
				color: var(--accent);
				background: var(--accent-subtle);
			}

			/* Projects */
			.projects-container {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1rem;
			}

			/* Skills — compact inline layout */
			.skills-inline {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 2rem;
			}

			.skill-group h3 {
				font-family: var(--font-mono);
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--accent);
				margin-bottom: 0.5rem;
			}

			.skill-group p {
				color: var(--text-secondary);
				font-size: 0.9rem;
				line-height: 1.8;
			}

			/* Footer */
			.social-links {
				display: flex;
				justify-content: center;
				gap: 1.5rem;
				padding: 2rem 0 3rem;
				border-top: 1px solid var(--border);
			}

			.social-links a {
				opacity: 0.4;
				transition: opacity 0.2s ease;
			}

			.social-links a:hover {
				opacity: 1;
			}

			.social-links img {
				width: 28px;
				height: 28px;
				filter: brightness(0) invert(1);
			}

			/* Responsive */
			@media (max-width: 640px) {
				body {
					padding: 1.25rem;
				}

				h1 {
					font-size: 2.25rem;
				}

				.projects-container {
					grid-template-columns: 1fr;
				}

				.header-cta {
					flex-wrap: wrap;
				}
			}

			@media (min-width: 768px) {
				body {
					padding: 3rem;
				}

				.skills-inline {
					grid-template-columns: 1fr 1fr 1fr;
				}
			}

			/* Subtle entrance animation */
			@keyframes fadeUp {
				from {
					opacity: 0;
					transform: translateY(12px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			header {
				animation: fadeUp 0.5s ease both;
			}

			.projects {
				animation: fadeUp 0.5s ease 0.1s both;
			}

			.tools {
				animation: fadeUp 0.5s ease 0.2s both;
			}

			.social-links {
				animation: fadeUp 0.5s ease 0.3s both;
			}

			.footer-email {
				font-family: var(--font-mono);
				font-size: 0.8rem;
				color: var(--text-secondary);
				opacity: 0.6;
				align-self: center;
			}
		</style>
	</head>
	<body>
		<div class="container">
			<main>
				<header>
					<div class="header-content">
						<p class="eyebrow">UBC Computer Science · 3.9 GPA · US Citizen</p>
						<h1>Spencer Fletcher</h1>
						<p class="subtitle">
							I build systems that hold up under real conditions — from compiler
							tooling to full stack web apps to real-time distributed systems.
							Right now I'm finishing my CS degree at UBC and overhauling my
							recipe platform. Looking for software engineering roles starting
							fall 2026.
						</p>
					</div>

					<div class="header-cta">
						<a href="mailto:spencer@spencerfletcher.com" class="cta-button">
							Email Me
						</a>
						<a
							target="_blank"
							href="/Spencer_Fletcher.pdf"
							class="cta-button cta-button-secondary">Resume ↗</a
						>
						<a
							target="_blank"
							href="https://linkedin.com/in/spencer-fletcher-dev"
							class="cta-button cta-button-secondary">LinkedIn ↗</a
						>
					</div>
				</header>

				<section class="projects">
					<h2>Projects</h2>

					<div class="projects-container">
						<ProjectCard
							featured
							title="MemoryGuard"
							year="2024"
							description="A Clang/LLVM-based memory safety tool for C programs. Combines static instrumentation with dynamic runtime analysis to detect dangling pointers, memory leaks, and double-frees, generating annotated, syntax-highlighted error reports with precise source locations."
							tags={["C++", "Clang/LLVM", "CMake", "Python"]}
							links={[
								{
									label: "View Code →",
									href: "https://github.com/spencerfletcher/MemoryGuard",
								},
							]}
							href="https://github.com/spencerfletcher/MemoryGuard"
						/>

						<ProjectCard
							title="PolymarketBot"
							year="2026 - Ongoing"
							description="Real-time arbitrage detection across <strong>5000 tokens and 2600 prediction markets</strong> via persistent WebSocket connections. Distributed event-driven architecture with cross-platform odds matching and safety mechanisms for graceful degradation."
							tags={["Python", "Distributed Systems", "Real-Time"]}
							links={[]}
							note="Closed source."
						/>

						<ProjectCard
							title="UBC Cadaver Donation Website"
							year="2022 - 2023"
							description="Redesigned UBC's Cadaver Donation Program webpage, driving a <strong>100%+ increase in donations</strong>. Also overhauled a staff directory serving hundreds of users, improving <strong>search speed by 250%</strong>."
							tags={["HTML", "CSS", "JavaScript", "WordPress"]}
							links={[
								{
									label: "View Code →",
									href: "https://github.com/spencerfletcher/body-donation-site",
								},
								{
									label: "Live Project →",
									href: "https://cps.med.ubc.ca/body-donation/",
								},
							]}
							href="https://cps.med.ubc.ca/body-donation/"
						/>

						<ProjectCard
							title="Fork: A Git-Style Recipe Platform"
							year="2025 - Ongoing"
							description="A full-stack recipe platform with <strong>Git-style version control</strong> for tracking recipe modifications and forking others' recipes. Built with SvelteKit and PostgreSQL, featuring user auth, image storage, and a public feed."
							tags={["SvelteKit", "PostgreSQL", "TypeScript"]}
							links={[
								{
									label: "View Code →",
									href: "https://github.com/spencerfletcher/Fork",
								},
							]}
							href="https://github.com/spencerfletcher/Fork"
						/>

						<ProjectCard
							title="Hollywood Theatre Automation"
							year="2024 · Freelance"
							description="Built tooling for the Hollywood Theatre in Vancouver — a web-based marquee letter tracker and a tip-splitting system, saving <strong>5+ hours of manual work weekly</strong>."
							tags={["JavaScript", "Google Apps Script"]}
							note="Source unavailable — client project."
						/>
					</div>
				</section>

				<section class="tools">
					<h2>Technical Skills</h2>
					<div class="skills-inline">
						<div class="skill-group">
							<h3>Programming</h3>
							<p>
								Python · TypeScript · JavaScript · Java · C/C++ · Assembly ·
								Erlang · R
							</p>
						</div>
						<div class="skill-group">
							<h3>Web & Frameworks</h3>
							<p>
								SvelteKit · Next.js · Django · Node.js · React Native · Tailwind
							</p>
						</div>
						<div class="skill-group">
							<h3>Infrastructure</h3>
							<p>Git · Docker · PostgreSQL · AWS · CI/CD · Clang/LLVM</p>
						</div>
					</div>
				</section>
			</main>

			<footer class="social-links">
				<a
					href="https://github.com/spencerfletcher"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="GitHub Profile"
				>
					<img src="/github.svg" height="24" width="24" alt="" />
				</a>
				<a
					href="https://www.linkedin.com/in/spencer-fletcher-dev"
					target="_blank"
					rel="noopener noreferrer"
					aria-label="LinkedIn Profile"
				>
					<img src="/linkedin.png" height="24" width="24" alt="" />
				</a>
				<a href="mailto:spencer@spencerfletcher.com" class="footer-email">
					spencer@spencerfletcher.com
				</a>
			</footer>
		</div>
		<script>
			document
				.querySelectorAll(".projects-container article[role='link']")
				.forEach((article) => {
					// Stop link clicks from also triggering the card's onclick
					article.querySelectorAll(".links a").forEach((a) => {
						a.addEventListener("click", (e) => e.stopPropagation());
					});
					// Enable keyboard navigation (Enter/Space) on cards
					article.addEventListener("keydown", (e) => {
						const event = e as KeyboardEvent;
						if (event.key === "Enter" || event.key === " ") {
							e.preventDefault();
							(article as HTMLElement).click();
						}
					});
				});
		</script>
	</body>
</html>
